{% extends "base.html" %}

{% block title %}Thay đổi mật khẩu{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Page Header -->
            <div class="mb-4">
                <h2 class="mb-2">Thay đổi mật khẩu</h2>
                <p class="text-muted">Cập nhật mật khẩu để bảo mật tài khoản của bạn</p>
            </div>

            <!-- Messages -->
            {% if messages %}
                <div class="mb-4">
                    {% for message in messages %}
                        <div class="alert alert-{{ message.tags }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <!-- Password Change Form -->
            <div class="card">
                <div class="card-body">
                    <form method="post">
                        {% csrf_token %}

                        <!-- Old Password -->
                        <div class="mb-3">
                            <label for="{{ form.old_password.id_for_label }}" class="form-label">
                                Mật khẩu hiện tại
                            </label>
                            {{ form.old_password }}
                            {% if form.old_password.help_text %}
                                <small class="form-text text-muted d-block mt-2">{{ form.old_password.help_text|safe }}</small>
                            {% endif %}
                            {% if form.old_password.errors %}
                                <div class="alert alert-danger mt-2">
                                    <ul class="mb-0">
                                        {% for error in form.old_password.errors %}
                                            <li>{{ error }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                        </div>

                        <!-- New Password -->
                        <div class="mb-3">
                            <label for="{{ form.new_password1.id_for_label }}" class="form-label">
                                Mật khẩu mới
                            </label>
                            {{ form.new_password1 }}
                            {% if form.new_password1.help_text %}
                                <small class="form-text text-muted d-block mt-2">{{ form.new_password1.help_text|safe }}</small>
                            {% endif %}
                            {% if form.new_password1.errors %}
                                <div class="alert alert-danger mt-2">
                                    <ul class="mb-0">
                                        {% for error in form.new_password1.errors %}
                                            <li>{{ error }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                        </div>

                        <!-- Confirm New Password -->
                        <div class="mb-4">
                            <label for="{{ form.new_password2.id_for_label }}" class="form-label">
                                Xác nhận mật khẩu mới
                            </label>
                            {{ form.new_password2 }}
                            {% if form.new_password2.help_text %}
                                <small class="form-text text-muted d-block mt-2">{{ form.new_password2.help_text|safe }}</small>
                            {% endif %}
                            {% if form.new_password2.errors %}
                                <div class="alert alert-danger mt-2">
                                    <ul class="mb-0">
                                        {% for error in form.new_password2.errors %}
                                            <li>{{ error }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                        </div>

                        <!-- Form Errors -->
                        {% if form.non_field_errors %}
                            <div class="alert alert-danger mb-4">
                                <strong>Lỗi:</strong>
                                <ul class="mb-0">
                                    {% for error in form.non_field_errors %}
                                        <li>{{ error }}</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}

                        <!-- Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Cập nhật mật khẩu
                            </button>
                            <a href="{% url 'forum:account_settings' %}" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Info Box -->
            <div class="alert alert-info mt-4">
                <h6 class="alert-heading">
                    <i class="fas fa-info-circle"></i> Yêu cầu mật khẩu an toàn
                </h6>
                <ul class="mb-0">
                    <li>Không được giống như các thông tin cá nhân của bạn</li>
                    <li>Phải có ít nhất 8 ký tự</li>
                    <li>Không được là mật khẩu quá phổ biến</li>
                    <li>Không được chỉ là số</li>
                </ul>
            </div>

            <!-- Back Link -->
            <div class="mt-4">
                <a href="{% url 'forum:user_profile' request.user.username %}" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-arrow-left"></i> Quay lại hồ sơ
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
</file>

<file path="forum/templates/forum/user_profile.html">
{% extends "base.html" %}

{% block title %}Hồ sơ của {{ target_user.username }}{% endblock %}

{% block content %}
<div class="container mt-5">
    <!-- Header Profile -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row align-items-center">
                <!-- Avatar -->
                <div class="col-md-3 text-center">
                    {% if target_user.avatar %}
                        <img src="{{ target_user.avatar.url }}" alt="{{ target_user.username }}" class="img-fluid rounded-circle" style="max-width: 150px; max-height: 150px; object-fit: cover;">
                    {% else %}
                        <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 150px; height: 150px;">
                            <span class="text-white fs-1">{{ target_user.username|first|upper }}</span>
                        </div>
                    {% endif %}
                </div>

                <!-- User Info -->
                <div class="col-md-9">
                    <h2>{{ target_user.get_display_name }}</h2>
                    <p class="text-muted">@{{ target_user.username }}</p>

                    <!-- Role Badge -->
                    <div class="mb-3">
                        {% if target_user.role == 'admin' %}
                            <span class="badge bg-danger">Admin</span>
                        {% elif target_user.role == 'moderator' %}
                            <span class="badge bg-warning">Moderator</span>
                        {% else %}
                            <span class="badge bg-info""">Member</span>
                        {% endif %}
                    </div>

                    <!-- Bio -->
                    {% if target_user.bio %}
                        <p class="card-text">{{ target_user.bio }}</p>
                    {% else %}
                        <p class="card-text text-muted"><em>Chưa có tiểu sử</em></p>
                    {% endif %}

                    <!-- Stats -->
                    <div class="row text-center mt-4">
                        <div class="col-sm-4">
                            <h5>{{ thread_count }}</h5>
                            <p class="text-muted">Threads</p>
                        </div>
                        <div class="col-sm-4">
                            <h5>{{ comment_count }}</h5>
                            <p class="text-muted">Comments</p>
                        </div>
                        <div class="col-sm-4">
                            <h5>{{ target_user.date_joined|date:"d/m/Y" }}</h5>
                            <p class="text-muted">Joined</p>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    {% if is_own_profile %}
                        <div class="mt-4">
                            <a href="{% url 'forum:account_settings' %}" class="btn btn-primary">
                                <i class="fas fa-edit"></i> Cập nhật hồ sơ
                            </a>
                            <a href="{% url 'forum:password_change' %}" class="btn btn-secondary">
                                <i class="fas fa-lock"></i> Thay đổi mật khẩu
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Threads -->
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">Threads gần đây ({{ thread_count }} tổng cộng)</h4>
        </div>
        <div class="card-body">
            {% if user_threads %}
                <div class="list-group">
                    {% for thread in user_threads %}
                        <a href="{% url 'forum:detail' thread.id %}" class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">{{ thread.title }}</h6>
                                <small class="text-muted">{{ thread.created_at|date:"d/m/Y H:i" }}</small>
                            </div>
                            <p class="mb-1 text-truncate">{{ thread.content|truncatewords:15 }}</p>
                            <small class="text-muted">
                                <i class="fas fa-comments"></i> {{ thread.comments.count }} bình luận
                            </small>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted text-center py-4">
                    <em>Chưa có thread nào được xuất bản</em>
                </p>
            {% endif %}
        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-4">
        <a href="{% url 'forum:index' %}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
{% endblock %}
</file>

