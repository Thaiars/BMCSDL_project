<script>
// Global helper to attach preview handler to reply file inputs
window.attachReplyPreviewHandler = function(input){
  if(!input || input._previewAttached) return;
  input._previewAttached = true;
  var id = input.id.replace('reply-image-','');
  var preview = document.getElementById('reply-preview-' + id);
  var removeBtn = document.querySelector('.remove-reply-image[data-id="' + id + '"]');
  var lastUrl = null;
  input.addEventListener('change', function(){
    var file = input.files && input.files[0];
    if(file){
      if(lastUrl) URL.revokeObjectURL(lastUrl);
      lastUrl = URL.createObjectURL(file);
      if(preview){ preview.src = lastUrl; preview.style.display = 'block'; preview.classList.remove('d-none'); }
      if(removeBtn){ removeBtn.classList.remove('d-none'); }
    } else {
      if(preview){ preview.src = ''; preview.style.display = 'none'; preview.classList.add('d-none'); }
      if(removeBtn){ removeBtn.classList.add('d-none'); }
      if(lastUrl){ URL.revokeObjectURL(lastUrl); lastUrl = null; }
    }
  });
  if(removeBtn){
    removeBtn.addEventListener('click', function(){ input.value = ''; input.dispatchEvent(new Event('change')); });
  }
};

// Global helper to attach preview handler to main file input
window.attachMainPreviewHandler = function(input){
  if(!input || input._previewAttached) return;
  input._previewAttached = true;
  var preview = document.getElementById('main-image-preview');
  var removeBtn = document.getElementById('main-remove-image');
  var lastUrl = null;
  input.addEventListener('change', function(){
    var file = input.files && input.files[0];
    if(file){
      if(lastUrl) URL.revokeObjectURL(lastUrl);
      lastUrl = URL.createObjectURL(file);
      if(preview){ preview.src = lastUrl; preview.style.display = 'block'; preview.classList.remove('d-none'); }
      if(removeBtn){ removeBtn.classList.remove('d-none'); }
    } else {
      if(preview){ preview.src = ''; preview.style.display = 'none'; preview.classList.add('d-none'); }
      if(removeBtn){ removeBtn.classList.add('d-none'); }
      if(lastUrl){ URL.revokeObjectURL(lastUrl); lastUrl = null; }
    }
  });
  if(removeBtn){
    removeBtn.addEventListener('click', function(){ input.value = ''; input.dispatchEvent(new Event('change')); });
  }
};

// Unified delegated handlers for all interactions
document.addEventListener('click', function(e){
  var el = e.target.closest && e.target.closest('.reply-toggle, .image-trigger, #main-image-trigger, .cancel-reply');
  if(!el) return;
  
  // Reply toggle
  if(el.classList && el.classList.contains('reply-toggle')){
    e.preventDefault();
    var id = el.dataset.id;
    var area = document.getElementById('reply-area-' + id);
    if(!area) return;
    var isOpen = area.style.display === 'block';
    document.querySelectorAll('.reply-area').forEach(function(a){ if(a.id !== 'reply-area-' + id) a.style.display = 'none'; });
    if(!isOpen){ area.style.display = 'block'; var mainForm = document.getElementById('comment-form'); if(mainForm) mainForm.style.display = 'none'; var ta = area.querySelector('textarea'); if(ta) ta.focus(); }
    else { area.style.display = 'none'; var mainForm = document.getElementById('comment-form'); if(mainForm) mainForm.style.display = 'block'; }
    return;
  }
  
  // Cancel reply
  if(el.classList && el.classList.contains('cancel-reply')){
    var id = el.dataset.id; var area = document.getElementById('reply-area-' + id);
    if(!area) return;
    area.style.display = 'none';
    var ta = area.querySelector('textarea'); if(ta) ta.value = '';
    var input = area.querySelector('input[type=file]'); if(input){ input.value = ''; input.dispatchEvent(new Event('change')); }
    var preview = area.querySelector('.reply-image-preview'); if(preview){ preview.src = ''; preview.style.display = 'none'; preview.classList.add('d-none'); }
    var removeBtn = area.querySelector('.remove-reply-image'); if(removeBtn){ removeBtn.classList.add('d-none'); }
    var mainForm = document.getElementById('comment-form'); if(mainForm) mainForm.style.display = 'block';
    return;
  }
  
  // Image trigger (main or reply)
  if(el.id === 'main-image-trigger' || (el.classList && el.classList.contains('image-trigger'))){
    e.preventDefault();
    if(el.id === 'main-image-trigger'){
      var mainInput = document.querySelector('#comment-form input[type=file]') || document.getElementById('id_image');
      if(mainInput){ attachMainPreviewHandler(mainInput); setTimeout(function(){ try{ mainInput.click(); }catch(err){ console.error(err); } }, 10); }
      else console.warn('[warn] main image input not found');
      return;
    }
    var id = el.dataset.id;
    var input = document.getElementById('reply-image-' + id);
    if(!input) input = document.getElementById('reply-area-' + id) && document.getElementById('reply-area-' + id).querySelector('input[type=file]');
    var area = document.getElementById('reply-area-' + id);
    if(area){ area.style.display = 'block'; var mainForm = document.getElementById('comment-form'); if(mainForm) mainForm.style.display = 'none'; }
    if(input){ attachReplyPreviewHandler(input); setTimeout(function(){ try{ input.click(); }catch(err){ console.error(err); } }, 10); }
    else console.warn('[warn] reply image input not found for id', id);
    return;
  }
});
</script>

