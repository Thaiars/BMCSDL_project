<file path="forum/static/forum/theme.css">
:root{
  --brand-teal: #0b1467; /* main teal */
  --brand-dark: #8681cc;
  --muted: #6c757d;
}

body{
  background-color: #ffffff;
  color: #1f2937;
}

.navbar{
  background: linear-gradient(180deg, #ffffff, #fbfeff);
  border-bottom: 1px solid #e9f5f3;
}

.navbar-brand{
  color: var(--brand-dark) !important;
  font-weight: 600;
}

.nav-link{
  color: var(--muted) !important;
}

.btn-primary{
  background-color: var(--brand-teal);
  border-color: var(--brand-teal);
}
.btn-primary:hover{
  background-color: var(--brand-dark);
  border-color: var(--brand-dark);
}

main.container{
  max-width: 900px;
}

.card-soft{
  background: #ffffff;
  border: 1px solid #eaf7f5;
  box-shadow: 0 1px 2px rgba(13,148,136,0.04);
  border-radius: .5rem;
  padding: 1rem;
}

.list-group-item{
  border: 1px solid #f0fbfa;
}

.thread-title{
  color: var(--brand-dark);
  font-weight: 600;
}

.small-muted{ color: #88919a; }

footer.site-footer{
  margin-top: 3rem;
  padding: 1.5rem 0;
  border-top: 1px solid #eef8f7;
  color: #6b7275;
}

/* Form controls fallback styling so Django default widgets look good */
.card-soft input[type="text"],
.card-soft input[type="search"],
.card-soft input[type="password"],
.card-soft input[type="email"],
.card-soft textarea,
.card-soft select {
  display: block;
  width: 100%;
  padding: .5rem .75rem;
  font-size: 1rem;
  line-height: 1.5;
  color: #495057;
  background-color: #fff;
  background-clip: padding-box;
  border: 1px solid #d6f0ec;
  border-radius: .375rem;
  transition: border-color .15s ease-in-out, box-shadow .15s ease-in-out;
}
.card-soft textarea { min-height: 120px; }
.card-soft input:focus, .card-soft textarea:focus {
  border-color: var(--brand-teal);
  box-shadow: 0 0 0 .15rem rgba(13,148,136,0.08);
  outline: 0;
}

.btn-secondary {
  background-color: #f8faf9;
  color: var(--brand-dark);
  border: 1px solid #e6f2f0;
}

.thread-meta { color: #667781; font-size: .95rem; }

/* Inline reply / comment action icons */
.comment-actions a { text-decoration: none; font-size: 1.05rem; }
.reply-area { margin-top: .5rem; }
.reply-inline-form .btn-sm { padding: .25rem .5rem; }
.reply-inline-form textarea { min-height: 60px; }
.comment-actions a:hover { color: var(--brand-teal); }

/* hide default file input when using icon trigger */
.d-none { display: none !important; }

/* delete button small style */
.btn-link.text-danger { color: #d9534f; }
.btn-link.text-danger:hover { color: #b52b26; text-decoration: none; }

/* image preview styles */
.reply-image-preview { display: block; margin-top: .5rem; max-height: 180px; }
.main-image-preview { display: block; margin-left: .5rem; max-height: 360px; }
.remove-reply-image { vertical-align: middle; }

/* SVG icon sizing and color */
.icon-svg { width: 16px; height: 16px; vertical-align: text-bottom; color: #88919a; }
.comment-actions .icon-svg { margin-right: 2px; }
.icon-svg:hover { color: var(--brand-teal); }

/* visually hide file inputs (off-screen) so .click() opens file picker */
.file-offscreen { position: absolute !important; left: -9999px !important; width: 1px !important; height: 1px !important; overflow: hidden !important; }

/* textarea container with inline icon */
.textarea-with-icon { position: relative; }
.textarea-with-icon .textarea-icon { position: absolute; right: 8px; bottom: 10px; cursor: pointer; z-index: 5; display: inline-flex; align-items: center; justify-content: center; color: #88919a; }
.textarea-with-icon .textarea-icon:hover { color: var(--brand-teal); }
.textarea-with-icon textarea { padding-right: 44px; }
</file>

